{
  "name": "blue-agent-connect",
  "version": "2.0.0",
  "description": "Zero-config decentralized VPN for AI agents. One function call from zero to encrypted P2P tunnel. No API keys, no accounts, no servers.",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "bin": {
    "blue-agent-connect": "./cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "*.js",
    "*.mjs",
    "*.d.ts",
    "*.vbs",
    "*.md",
    "cli/",
    "examples/",
    ".env.example",
    "LICENSE"
  ],
  "scripts": {
    "setup": "node setup.js",
    "postinstall": "node setup.js || echo '[blue-agent-connect] Setup incomplete — run npm run setup'",
    "connect": "node cli.js connect",
    "test": "node -e \"import('./index.js').then(m => console.log('OK:', Object.keys(m).length, 'exports'))\""
  },
  "keywords": [
    "agent", "vpn", "dvpn", "sentinel", "ai", "decentralized", "wireguard",
    "v2ray", "socks5", "privacy", "autonomous", "p2p", "split-tunnel",
    "bandwidth", "censorship-resistant", "peer-to-peer", "x402"
  ],
  "license": "MIT",
  "author": "Norse Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sentinel-Autonomybuilder/blue-agent-connect.git"
  },
  "bugs": {
    "url": "https://github.com/Sentinel-Autonomybuilder/blue-agent-connect/issues"
  },
  "homepage": "https://github.com/Sentinel-Autonomybuilder/blue-agent-connect#readme",
  "dependencies": {
    "blue-js-sdk": "^2.3.0",
    "axios": "^1.7.0",
    "socks-proxy-agent": "^8.0.0"
  }
}
